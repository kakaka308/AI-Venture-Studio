// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation("AccountOnUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id          String   @id @default(cuid())
  sessionToken String  @unique
  userId      String
  expires     DateTime

  user User @relation("SessionOnUser", fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id       String    @id @default(cuid())
  email    String    @unique
  password String
  name     String?
  image    String?
  emailVerified DateTime?
  projects Project[] @relation("ProjectOnUser")
  sessions Session[] @relation("SessionOnUser")
  accounts Account[] @relation("AccountOnUser")
  conversations Conversation[] @relation("ConversationOnUser")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id             String   @id @default(cuid())
  name           String
  description    String?
  industry       String?
  targetAudience String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId         String
  user           User     @relation("ProjectOnUser", fields: [userId], references: [id], onDelete: Cascade)

  // 项目上下文（一对一）
  context        ProjectContext?

  // 项目长期记忆（一对一）
  memory         ProjectMemory?

  // 项目任务（一对多）
  tasks          Task[]

  // 项目知识库（一对多）
  knowledgeDocuments KnowledgeDocument[]
}

model ProjectContext {
  id               String   @id @default(cuid())
  projectId        String   @unique
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  industry         String?
  targetAudience   String?
  problem          String?
  valueProposition String?
  competitors      String?
  stage            String?  @default("idea") // idea | validation | prototype | mvp

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("project_contexts")
}

model Conversation {
  id        String   @id @default(cuid())
  title     String   @default("New Conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // 关联用户
  userId    String
  user      User     @relation("ConversationOnUser", fields: [userId], references: [id], onDelete: Cascade)
  
  // 关联消息
  messages  Message[]
  
  @@index([userId])
}

model ProjectMemory {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 项目画像：结构化 JSON 存储 Agent 学到的项目知识
  portrait  Json     @default("{\"industry\":\"\",\"targetUsers\":\"\",\"businessModel\":\"\",\"keyInsights\":[],\"summary\":\"\"}")
  // 最后一次从对话中提取学习的时间
  lastExtractedAt DateTime?
  updatedAt DateTime @updatedAt

  @@map("project_memories")
}

model Message {
  id             String   @id @default(cuid())
  content        String
  role           String   // "user" | "assistant" | "system"
  createdAt      DateTime @default(now())
  
  // 关联对话
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
}

// ---------------------------------------------------------------------------
//  Task - 项目任务管理
// ---------------------------------------------------------------------------
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  priority    String    @default("medium")   // low | medium | high | urgent
  status      String    @default("todo")      // todo | in_progress | done | cancelled
  dueDate     DateTime?
  assignedTo  String?                         // 负责人（用户 ID 或姓名）
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 关联项目
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@map("tasks")
}

// ---------------------------------------------------------------------------
//  KnowledgeDocument - 知识文档（支持上传和手动输入）
// ---------------------------------------------------------------------------

model KnowledgeDocument {
  id        String   @id @default(cuid())
  fileName  String
  fileType  String   // pdf | markdown | txt
  fileSize  Int
  content   String   @db.Text
  metadata  Json?    // 额外元数据
  createdAt DateTime @default(now())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // 关联分块
  chunks    KnowledgeChunk[]
  
  @@map("knowledge_documents")
}

// ---------------------------------------------------------------------------
//  KnowledgeChunk - 文档分块（含向量嵌入）
// ---------------------------------------------------------------------------
model KnowledgeChunk {
  id        String   @id @default(cuid())
  document  KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String
  
  content   String   @db.Text
  chunkIndex Int
  embedding Unsupported("vector(1536)")?
  
  createdAt DateTime @default(now())
  
  @@index([documentId])
  @@map("knowledge_chunks")
}

